{
  "info": {
    "name": "NexaMind AI Platform",
    "description": "Complete API collection for testing NexaMind AI Platform - Graduation Project\n\nSetup:\n1. Import this collection\n2. Set TENANT_ID and TOKEN variables after registering\n3. Run requests in order",
    "_postman_id": "nexamind-2024",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "BASE_ORCHESTRATOR",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "BASE_AUTH",
      "value": "http://localhost:8001",
      "type": "string"
    },
    {
      "key": "BASE_LLM",
      "value": "http://localhost:8002",
      "type": "string"
    },
    {
      "key": "BASE_RAG",
      "value": "http://localhost:8003",
      "type": "string"
    },
    {
      "key": "TENANT_ID",
      "value": "PASTE_YOUR_TENANT_ID_HERE",
      "type": "string"
    },
    {
      "key": "TOKEN",
      "value": "PASTE_YOUR_ACCESS_TOKEN_HERE",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "01 - Health Checks",
      "item": [
        {
          "name": "Health - Orchestrator",
          "request": {
            "method": "GET",
            "url": "{{BASE_ORCHESTRATOR}}/health",
            "description": "Check if the main agent orchestrator is running"
          }
        },
        {
          "name": "Health - Auth Service",
          "request": {
            "method": "GET",
            "url": "{{BASE_AUTH}}/health",
            "description": "Check if auth service is running"
          }
        },
        {
          "name": "Health - LLM Gateway",
          "request": {
            "method": "GET",
            "url": "{{BASE_LLM}}/api/v1/health",
            "description": "Check if LLM gateway (Groq) is running"
          }
        },
        {
          "name": "Health - RAG Service",
          "request": {
            "method": "GET",
            "url": "{{BASE_RAG}}/health",
            "description": "Check if RAG service with local embeddings is running"
          }
        },
        {
          "name": "List Available LLM Models",
          "request": {
            "method": "GET",
            "url": "{{BASE_LLM}}/api/v1/models",
            "description": "See what Groq models are available"
          }
        }
      ]
    },
    {
      "name": "02 - Authentication",
      "item": [
        {
          "name": "Register New Tenant",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.tenant && json.tenant.id) {",
                  "    pm.collectionVariables.set('TENANT_ID', json.tenant.id);",
                  "    pm.collectionVariables.set('TOKEN', json.access_token);",
                  "    console.log('TENANT_ID saved:', json.tenant.id);",
                  "    console.log('TOKEN saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{BASE_AUTH}}/api/v1/auth/register",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Company\",\n  \"slug\": \"testco\",\n  \"admin_email\": \"admin@testco.com\",\n  \"admin_password\": \"Admin1234!\",\n  \"admin_full_name\": \"Test Admin\"\n}"
            },
            "description": "Creates a new tenant + admin user. TENANT_ID and TOKEN are saved automatically to collection variables."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access_token) {",
                  "    pm.collectionVariables.set('TOKEN', json.access_token);",
                  "    console.log('TOKEN updated');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{BASE_AUTH}}/api/v1/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@testco.com\",\n  \"password\": \"Admin1234!\"\n}"
            },
            "description": "Login and get JWT token. Token is saved automatically."
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": "{{BASE_AUTH}}/api/v1/auth/me",
            "header": [
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "description": "Get info about the currently logged in user"
          }
        },
        {
          "name": "Generate API Key",
          "request": {
            "method": "POST",
            "url": "{{BASE_AUTH}}/api/v1/auth/api-key",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Test API Key\",\n  \"scopes\": [\"read\", \"write\"]\n}"
            },
            "description": "Generate an API key. The full key is only shown once in the response - save it!"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{BASE_AUTH}}/api/v1/auth/refresh",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"PASTE_REFRESH_TOKEN_HERE\"\n}"
            },
            "description": "Get a new access token using refresh token"
          }
        }
      ]
    },
    {
      "name": "03 - LLM Gateway (Groq)",
      "item": [
        {
          "name": "Chat Completion - Llama3 70B",
          "request": {
            "method": "POST",
            "url": "{{BASE_LLM}}/api/v1/chat/completions",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-Id", "value": "{{TENANT_ID}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"llama3-70b-8192\",\n  \"messages\": [\n    {\"role\": \"user\", \"content\": \"What is machine learning in 2 sentences?\"}\n  ],\n  \"max_tokens\": 200,\n  \"temperature\": 0.7\n}"
            },
            "description": "Direct call to Groq Llama3 70B model"
          }
        },
        {
          "name": "Chat Completion - Llama3 8B (faster)",
          "request": {
            "method": "POST",
            "url": "{{BASE_LLM}}/api/v1/chat/completions",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-Id", "value": "{{TENANT_ID}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"llama3-8b-8192\",\n  \"messages\": [\n    {\"role\": \"user\", \"content\": \"Say hello in 5 different languages\"}\n  ],\n  \"max_tokens\": 200,\n  \"temperature\": 0.5\n}"
            },
            "description": "Faster, smaller Groq model"
          }
        },
        {
          "name": "Chat with System Prompt",
          "request": {
            "method": "POST",
            "url": "{{BASE_LLM}}/api/v1/chat/completions",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-Id", "value": "{{TENANT_ID}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"default\",\n  \"system\": \"You are a helpful financial analyst. Always give specific numbers.\",\n  \"messages\": [\n    {\"role\": \"user\", \"content\": \"What are typical profit margins in SaaS businesses?\"}\n  ],\n  \"max_tokens\": 300,\n  \"temperature\": 0.3\n}"
            },
            "description": "Using model=default picks the configured default (llama3-70b)"
          }
        }
      ]
    },
    {
      "name": "04 - RAG Service",
      "item": [
        {
          "name": "Upload Document",
          "request": {
            "method": "POST",
            "url": "{{BASE_RAG}}/api/v1/documents/upload",
            "header": [
              { "key": "X-Tenant-Id", "value": "{{TENANT_ID}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "Select a .txt, .pdf, .docx, or .csv file from your computer"
                },
                {
                  "key": "collection",
                  "value": "general",
                  "type": "text"
                }
              ]
            },
            "description": "Upload a document to the knowledge base. Select a file from your computer in the body tab."
          }
        },
        {
          "name": "Search Knowledge Base",
          "request": {
            "method": "POST",
            "url": "{{BASE_RAG}}/api/v1/search",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
